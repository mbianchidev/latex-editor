# Path on the host machine where project data (SQLite DB) is stored.
# This directory is bind-mounted into the backend container at /data.
# Default: ${HOME}/.latex-editor/data
LATEX_EDITOR_DATA=${HOME}/.latex-editor/data

# Host port used to open the editor.
LATEX_EDITOR_PORT=80

# Recommended: keep the Fernet key outside the database volume.
# Generate one with:
# docker compose run --rm --no-deps backend python -c \
#   "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GITHUB_TOKEN_ENCRYPTION_KEY=

# Optional generated-key path. Blank defaults beside projects.db in /data.
GITHUB_TOKEN_KEY_PATH=

# Server-side TeX compilation limits.
COMPILE_TIMEOUT_SECONDS=60
MAX_REQUEST_BYTES=36700160
MAX_COMPILE_BYTES=26214400
